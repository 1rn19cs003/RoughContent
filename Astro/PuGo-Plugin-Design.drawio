        <mxCell id="B4aIteWDy32EjZsqEO7i-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;PujaGo.com&lt;/b&gt;&#xa;&#xa;• Direct consumer app&#xa;• Full brand ownership&#xa;• Maximum margin&#xa;• Bangalore launch market" vertex="1">
          <mxGeometry height="110" width="220" x="120" y="460" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;MagicBricks / NoBroker&lt;/b&gt;&#xa;&#xa;• &#39;Book pandit for new home&#39;&#xa;• Embedded in property apps&#xa;• Revenue share model&#xa;• High-intent users (buyers)" vertex="1">
