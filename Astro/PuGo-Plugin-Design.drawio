        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;Wedding / Event platforms&lt;/b&gt;&#xa;&#xa;• WedMeGood, ShaadiSagaa&#xa;• Temple booking platforms&#xa;• Corporate event apps&#xa;• Per-API-call pricing" vertex="1">
          <mxGeometry height="110" width="240" x="980" y="460" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-18" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=2;fontColor=#666666;" value="How to build it plugin-ready from day 1" vertex="1">
          <mxGeometry height="25" width="320" x="40" y="600" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0C447C;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;1. Versioned API&lt;/b&gt;&#xa;&#xa;All routes under /api/v1/&#xa;OpenAPI / Swagger spec&#xa;Never break existing clients&#xa;Version bump for breaking changes" vertex="1">
          <mxGeometry height="120" width="220" x="120" y="630" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0C447C;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;2. Multi-tenancy&lt;/b&gt;&#xa;&#xa;Add tenantId to every Prisma model&#xa;Row-level data isolation&#xa;Per-tenant config (branding, fees)&#xa;Tenant API key management" vertex="1">
          <mxGeometry height="120" width="220" x="370" y="630" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0C447C;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;3. JS/TS SDK&lt;/b&gt;&#xa;&#xa;npm package: pujago-sdk&#xa;Wraps all API calls&#xa;React Native component kit&#xa;Drop-in BookingWidget component" vertex="1">
          <mxGeometry height="120" width="220" x="620" y="630" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-22" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0C447C;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;4. Webhooks&lt;/b&gt;&#xa;&#xa;booking.confirmed&#xa;booking.cancelled&#xa;puja.completed&#xa;payment.settled&#xa;samagri.delivered" vertex="1">
          <mxGeometry height="120" width="180" x="870" y="630" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0C447C;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" value="&lt;b&gt;5. Module toggles&lt;/b&gt;&#xa;&#xa;Enable/disable per tenant:&#xa;• Astrology module on/off&#xa;• Samagri delivery on/off&#xa;• Custom puja types&#xa;• Branded notifications" vertex="1">
          <mxGeometry height="120" width="200" x="1080" y="630" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-24" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=2;fontColor=#666666;" value="Astrology — separate pluggable module" vertex="1">
          <mxGeometry height="25" width="310" x="40" y="780" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#3C3489;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" value="&lt;b&gt;Astrology Module&lt;/b&gt; — /src/modules/astrology&#xa;&#xa;Services: Kundali · Horoscope · Dasha · Transits · Zodiac · Remedies&#xa;Models: KundaliRequest · AstrologerProfile · ConsultSession · ZodiacProfile&#xa;Same API gateway — enable/disable per tenant via feature flag&#xa;Pandit model extended: isAstrologer boolean + specializations array" vertex="1">
          <mxGeometry height="100" width="760" x="300" y="810" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-26" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=2;fontColor=#666666;" value="Recommended folder structure" vertex="1">
          <mxGeometry height="25" width="260" x="40" y="940" as="geometry" />
        </mxCell>
        <mxCell id="B4aIteWDy32EjZsqEO7i-27" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#614B00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontFamily=Courier New;" value="&lt;b&gt;Project structure (plugin-ready from day 1)&lt;/b&gt;&#xa;&#xa;/src/modules/booking        ← booking service&#xa;/src/modules/pandit         ← pandit service&#xa;/src/modules/samagri        ← samagri + delivery&#xa;/src/modules/astrology      ← pluggable astrology module&#xa;/src/modules/payment        ← payment + escrow&#xa;/src/modules/notification   ← push + SMS + email&#xa;&#xa;/src/plugins/sdk            ← pujago-sdk npm package&#xa;/src/plugins/webhooks       ← outbound webhook dispatcher&#xa;/src/plugins/widget         ← embeddable React Native widget&#xa;&#xa;/src/shared/auth            ← JWT + OTP middleware&#xa;/src/shared/queue           ← Bull job queue&#xa;/src/shared/storage         ← S3 upload helpers&#xa;/src/shared/tenant          ← multi-tenancy middleware&#xa;&#xa;/prisma/schema.prisma       ← your existing schema (add tenantId to all models)" vertex="1">
          <mxGeometry height="280" width="760" x="300" y="970" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
