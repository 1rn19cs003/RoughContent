        <mxCell id="B4aIteWDy32EjZsqEO7i-14" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=2;fontColor=#666666;" value="Real-world integration examples" vertex="1">
